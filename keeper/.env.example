# wstDIEM vault keeper — required env vars
# Store secrets in Railway environment variables (never commit values)

# Keeper EOA private key — signs settlements and AntSeed DHT identity
KEEPER_PRIVATE_KEY=0x...

# Venice AI API key — minted via vault.fundKeeperVVV + generate_web3_key
# 1P: op item get zfk52wt5di6kn3j76o6o7kngi4 --field venice_api_key
VENICE_API_KEY=VENICE_INFERENCE_...

# Base mainnet RPC (Alchemy)
# 1P: op item get avv7soxqnjtpj4nu77jdytmjeu --field credential
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/...

# Optional — settlement tuning
CHANNEL_ID=0            # AntSeed channel in FeeRouter (0 = first registered)
MIN_SETTLE_USDC=1.0     # Minimum USDC balance before settling (default: $1)
POLL_INTERVAL_MS=120000 # How often to check balance (default: 2 min)
